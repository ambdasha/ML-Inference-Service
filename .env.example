# Приложение
APP_NAME=ml-inference-service
ENVIRONMENT=development
DEBUG=true

# База данных
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=ml_password
POSTGRES_DB=ml_inference
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ml_user:ml_password@db:5432/ml_inference

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ML
MODEL_DIR=models
CATEGORY_MODEL_PATH=models/category_model.pkl
LEVEL_MODEL_PATH=models/level_model.pkl
VECTORIZER_PATH=models/vectorizer.pkl

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Cache
PREDICTION_CACHE_TTL_SECONDS=86400
